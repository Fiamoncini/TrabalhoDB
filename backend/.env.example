# Porta em que a API sobe
PORT=5000

# Conexao com o MongoDB.
# Local:  mongodb://127.0.0.1:27017/mercado_nosql
# Atlas:  mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/mercado_nosql
MONGODB_URI=mongodb://127.0.0.1:27017/mercado_nosql

# Segredo para assinar os tokens JWT — troque por algo aleatorio e secreto.
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-longa
JWT_EXPIRES_IN=7d

# Origem permitida no CORS (URL do frontend hospedado). Use * para liberar geral.
# Ex.: https://trabalhodb.onrender.com
CORS_ORIGIN=*
